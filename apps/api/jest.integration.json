{
  "moduleFileExtensions": ["ts", "js", "json"],
  "rootDir": ".",
  "testRegex": "test/integration/.*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": "<rootDir>/tsconfig.integration.json"
      }
    ]
  },
  "moduleNameMapper": {
    "^@agentforge/shared$": "<rootDir>/../../packages/shared/src/index.ts",
    "^@agentforge/shared/(.*)$": "<rootDir>/../../packages/shared/src/$1",
    "^(\\.{1,2}/.+)\\.js$": "$1"
  },
  "testEnvironment": "node",
  "testTimeout": 30000
}
