generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum user_role {
  owner
  admin
  developer
  viewer
  api_user
}

enum prompt_status {
  draft
  live
  archived
}

enum variable_type {
  string
  number
  boolean
  array
  object
}

enum org_plan {
  free
  pro
  enterprise
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  clerkId   String   @unique @map("clerk_id")
  email     String   @unique
  name      String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")

  orgMembers       OrgMember[]
  workspaceMembers WorkspaceMember[]
  prompts          Prompt[]
  promptVersions   PromptVersion[]

  @@map("users")
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  plan      org_plan @default(free)
  createdAt DateTime @default(now()) @map("created_at")

  members    OrgMember[]
  workspaces Workspace[]

  @@map("organizations")
}

model OrgMember {
  id       String    @id @default(uuid()) @db.Uuid
  orgId    String    @map("org_id") @db.Uuid
  userId   String    @map("user_id") @db.Uuid
  role     user_role
  joinedAt DateTime  @default(now()) @map("joined_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("org_members")
}

model Workspace {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String
  slug      String
  createdAt DateTime @default(now()) @map("created_at")

  org     Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members WorkspaceMember[]
  prompts Prompt[]

  @@unique([orgId, slug])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  role        user_role

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Prompt {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  name        String
  description String?
  status      prompt_status @default(draft)
  createdBy   String        @map("created_by") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User             @relation(fields: [createdBy], references: [id])
  versions  PromptVersion[]
  variables PromptVariable[]

  @@map("prompts")
}

model PromptVersion {
  id            String   @id @default(uuid()) @db.Uuid
  promptId      String   @map("prompt_id") @db.Uuid
  versionNumber Int      @map("version_number")
  content       String
  characterCount Int     @map("character_count")
  createdBy     String   @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  prompt  Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  creator User   @relation(fields: [createdBy], references: [id])

  @@unique([promptId, versionNumber])
  @@map("prompt_versions")
}

model PromptVariable {
  id           String        @id @default(uuid()) @db.Uuid
  promptId     String        @map("prompt_id") @db.Uuid
  name         String
  type         variable_type @default(string)
  description  String?
  defaultValue String?       @map("default_value")

  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, name])
  @@map("prompt_variables")
}
