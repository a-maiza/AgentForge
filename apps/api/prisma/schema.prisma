generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum user_role {
  owner
  admin
  developer
  viewer
  api_user
}

enum prompt_status {
  draft
  live
  archived
}

enum variable_type {
  string
  number
  boolean
  array
  object
}

enum org_plan {
  free
  pro
  enterprise
}

enum dataset_status {
  active
  archived
}

enum dataset_version_status {
  latest
  archived
}

enum eval_job_status {
  pending
  running
  completed
  failed
  cancelled
}

enum deployment_status {
  pending
  active
  inactive
  rolled_back
}

enum deployment_environment {
  dev
  staging
  prod
}

enum api_key_type {
  org
  workspace
  readonly
}

enum api_key_status {
  active
  disabled
  expired
}

enum agent_status {
  draft
  live
  archived
}

enum audit_action {
  dataset_created
  dataset_updated
  dataset_deleted
  dataset_version_uploaded
  deployment_created
  deployment_rolled_back
  deployment_went_live
  api_key_created
  api_key_disabled
  api_key_deleted
  agent_created
  agent_updated
  agent_deleted
  agent_workflow_saved
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  clerkId   String   @unique @map("clerk_id")
  email     String   @unique
  name      String?
  avatarUrl String?  @map("avatar_url")
  createdAt DateTime @default(now()) @map("created_at")

  orgMembers       OrgMember[]
  workspaceMembers WorkspaceMember[]
  prompts          Prompt[]
  promptVersions   PromptVersion[]
  datasets         Dataset[]
  evaluationJobs   EvaluationJob[]
  deployments      Deployment[]
  apiKeys          ApiKey[]
  agents           Agent[]
  agentVersions    AgentVersion[]
  auditLogs        AuditLog[]

  @@map("users")
}

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  plan      org_plan @default(free)
  createdAt DateTime @default(now()) @map("created_at")

  members    OrgMember[]
  workspaces Workspace[]

  @@map("organizations")
}

model OrgMember {
  id       String    @id @default(uuid()) @db.Uuid
  orgId    String    @map("org_id") @db.Uuid
  userId   String    @map("user_id") @db.Uuid
  role     user_role
  joinedAt DateTime  @default(now()) @map("joined_at")

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("org_members")
}

model Workspace {
  id        String   @id @default(uuid()) @db.Uuid
  orgId     String   @map("org_id") @db.Uuid
  name      String
  slug      String
  createdAt DateTime @default(now()) @map("created_at")

  org         Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members     WorkspaceMember[]
  prompts     Prompt[]
  datasets    Dataset[]
  aiProviders AiProvider[]
  apiKeys     ApiKey[]
  agents      Agent[]
  auditLogs   AuditLog[]

  @@unique([orgId, slug])
  @@map("workspaces")
}

model WorkspaceMember {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @map("workspace_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  role        user_role

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model Prompt {
  id          String        @id @default(uuid()) @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  name        String
  description String?
  status      prompt_status @default(draft)
  createdBy   String        @map("created_by") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  workspace      Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator        User                  @relation(fields: [createdBy], references: [id])
  versions       PromptVersion[]
  variables      PromptVariable[]
  datasetConfigs PromptDatasetConfig[]
  aiConfigs      PromptAiConfig[]
  evaluationJobs EvaluationJob[]
  deployments    Deployment[]
  failoverConfig FailoverConfig?

  @@map("prompts")
}

model PromptVersion {
  id            String   @id @default(uuid()) @db.Uuid
  promptId      String   @map("prompt_id") @db.Uuid
  versionNumber Int      @map("version_number")
  content       String
  characterCount Int     @map("character_count")
  createdBy     String   @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  prompt         Prompt          @relation(fields: [promptId], references: [id], onDelete: Cascade)
  creator        User            @relation(fields: [createdBy], references: [id])
  evaluationJobs EvaluationJob[]
  deployments    Deployment[]

  @@unique([promptId, versionNumber])
  @@map("prompt_versions")
}

model PromptVariable {
  id           String        @id @default(uuid()) @db.Uuid
  promptId     String        @map("prompt_id") @db.Uuid
  name         String
  type         variable_type @default(string)
  description  String?
  defaultValue String?       @map("default_value")

  prompt Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, name])
  @@map("prompt_variables")
}

model Dataset {
  id          String         @id @default(uuid()) @db.Uuid
  workspaceId String         @map("workspace_id") @db.Uuid
  name        String
  description String?
  status      dataset_status @default(active)
  createdBy   String         @map("created_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  workspace      Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator        User                  @relation(fields: [createdBy], references: [id])
  versions       DatasetVersion[]
  promptConfigs  PromptDatasetConfig[]
  evaluationJobs EvaluationJob[]

  @@map("datasets")
}

model DatasetVersion {
  id            String                 @id @default(uuid()) @db.Uuid
  datasetId     String                 @map("dataset_id") @db.Uuid
  versionNumber Int                    @map("version_number")
  storagePath   String                 @map("storage_path")
  rowCount      Int                    @map("row_count")
  columnCount   Int                    @map("column_count")
  fileSizeBytes BigInt                 @map("file_size_bytes")
  columns       Json
  status        dataset_version_status @default(latest)
  createdAt     DateTime               @default(now()) @map("created_at")

  dataset       Dataset               @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  promptConfigs PromptDatasetConfig[]
  evaluationJobs EvaluationJob[]

  @@unique([datasetId, versionNumber])
  @@index([storagePath])
  @@map("dataset_versions")
}

model PromptDatasetConfig {
  id               String  @id @default(uuid()) @db.Uuid
  promptId         String  @map("prompt_id") @db.Uuid
  datasetId        String  @map("dataset_id") @db.Uuid
  datasetVersionId String  @map("dataset_version_id") @db.Uuid
  variableMapping  Json    @map("variable_mapping")
  isActive         Boolean @default(true) @map("is_active")

  prompt         Prompt         @relation(fields: [promptId], references: [id], onDelete: Cascade)
  dataset        Dataset        @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  datasetVersion DatasetVersion @relation(fields: [datasetVersionId], references: [id], onDelete: Cascade)

  @@map("prompt_dataset_configs")
}

model AiProvider {
  id              String   @id @default(uuid()) @db.Uuid
  workspaceId     String   @map("workspace_id") @db.Uuid
  name            String
  providerType    String   @map("provider_type")
  apiKeyEncrypted String   @map("api_key_encrypted")
  baseUrl         String?  @map("base_url")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  workspace          Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  promptConfigs      PromptAiConfig[]
  evaluationJobs     EvaluationJob[]
  primaryFailovers   FailoverConfig[] @relation("primary_provider")
  secondaryFailovers FailoverConfig[] @relation("secondary_provider")

  @@map("ai_providers")
}

model PromptAiConfig {
  id          String  @id @default(uuid()) @db.Uuid
  promptId    String  @map("prompt_id") @db.Uuid
  providerId  String  @map("provider_id") @db.Uuid
  modelName   String  @map("model_name")
  temperature Float?
  topP        Float?  @map("top_p")
  topK        Int?    @map("top_k")
  maxTokens   Int?    @map("max_tokens")
  isActive    Boolean @default(true) @map("is_active")

  prompt   Prompt     @relation(fields: [promptId], references: [id], onDelete: Cascade)
  provider AiProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@map("prompt_ai_configs")
}

model EvaluationJob {
  id              String          @id @default(uuid()) @db.Uuid
  promptId        String          @map("prompt_id") @db.Uuid
  promptVersionId String          @map("prompt_version_id") @db.Uuid
  datasetId       String          @map("dataset_id") @db.Uuid
  datasetVersionId String         @map("dataset_version_id") @db.Uuid
  providerId      String          @map("provider_id") @db.Uuid
  modelName       String          @map("model_name")
  modelConfig     Json            @map("model_config")
  metrics         String[]
  status          eval_job_status @default(pending)
  progress        Int             @default(0)
  grade           String?
  startedAt       DateTime?       @map("started_at")
  completedAt     DateTime?       @map("completed_at")
  errorMessage    String?         @map("error_message")
  createdBy       String          @map("created_by") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at")

  prompt         Prompt           @relation(fields: [promptId], references: [id], onDelete: Cascade)
  promptVersion  PromptVersion    @relation(fields: [promptVersionId], references: [id])
  dataset        Dataset          @relation(fields: [datasetId], references: [id])
  datasetVersion DatasetVersion   @relation(fields: [datasetVersionId], references: [id])
  provider       AiProvider       @relation(fields: [providerId], references: [id])
  creator        User             @relation(fields: [createdBy], references: [id])
  results        EvaluationResult[]
  traces         EvaluationTrace[]

  @@index([promptId, status])
  @@map("evaluation_jobs")
}

model EvaluationResult {
  id          String   @id @default(uuid()) @db.Uuid
  jobId       String   @map("job_id") @db.Uuid
  metricName  String   @map("metric_name")
  score       Float
  grade       String?
  threshold   Float?
  details     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  job EvaluationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("evaluation_results")
}

model EvaluationTrace {
  id           String   @id @default(uuid()) @db.Uuid
  jobId        String   @map("job_id") @db.Uuid
  rowIndex     Int      @map("row_index")
  inputData    Json     @map("input_data")
  prediction   String
  reference    String?
  latencyMs    Int      @map("latency_ms")
  inputTokens  Int      @map("input_tokens")
  outputTokens Int      @map("output_tokens")
  error        String?
  createdAt    DateTime @default(now()) @map("created_at")

  job EvaluationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, rowIndex])
  @@map("evaluation_traces")
}

// ─── Phase 3: Deployment Pipeline ────────────────────────────────────────────

model Deployment {
  id              String                 @id @default(uuid()) @db.Uuid
  promptId        String                 @map("prompt_id") @db.Uuid
  promptVersionId String                 @map("prompt_version_id") @db.Uuid
  environment     deployment_environment
  status          deployment_status      @default(pending)
  /// Semver-like: MAJOR.MINOR.PATCH.BUILD
  versionLabel    String                 @map("version_label")
  endpointHash    String?                @unique @map("endpoint_hash")
  isLive          Boolean                @default(false) @map("is_live")
  deployedBy      String                 @map("deployed_by") @db.Uuid
  deployedAt      DateTime               @default(now()) @map("deployed_at")
  rolledBackAt    DateTime?              @map("rolled_back_at")
  notes           String?

  prompt        Prompt        @relation(fields: [promptId], references: [id], onDelete: Cascade)
  promptVersion PromptVersion @relation(fields: [promptVersionId], references: [id])
  deployer      User          @relation(fields: [deployedBy], references: [id])
  apiCallLogs   ApiCallLog[]

  @@index([promptId, environment])
  @@index([endpointHash])
  @@map("deployments")
}

model FailoverConfig {
  id                  String   @id @default(uuid()) @db.Uuid
  promptId            String   @unique @map("prompt_id") @db.Uuid
  primaryProviderId   String   @map("primary_provider_id") @db.Uuid
  secondaryProviderId String   @map("secondary_provider_id") @db.Uuid
  timeoutMs           Int      @default(30000) @map("timeout_ms")
  /// Number of errors before switching to secondary
  errorThreshold      Int      @default(3) @map("error_threshold")
  /// Max latency (ms) before triggering failover
  latencyThresholdMs  Int      @default(5000) @map("latency_threshold_ms")
  /// Seconds to wait before retrying primary after failover
  recoveryIntervalSec Int      @default(60) @map("recovery_interval_sec")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  prompt            Prompt     @relation(fields: [promptId], references: [id], onDelete: Cascade)
  primaryProvider   AiProvider @relation("primary_provider", fields: [primaryProviderId], references: [id])
  secondaryProvider AiProvider @relation("secondary_provider", fields: [secondaryProviderId], references: [id])

  @@map("failover_configs")
}

model ApiKey {
  id          String         @id @default(uuid()) @db.Uuid
  workspaceId String         @map("workspace_id") @db.Uuid
  name        String
  /// Prefix shown in UI: sk_org_ | sk_ws_ | sk_ro_
  prefix      String
  /// bcrypt hash of the full key — full key returned ONCE on creation
  keyHash     String         @map("key_hash")
  type        api_key_type   @default(workspace)
  status      api_key_status @default(active)
  expiresAt   DateTime?      @map("expires_at")
  lastUsedAt  DateTime?      @map("last_used_at")
  createdBy   String         @map("created_by") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at")

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator     User         @relation(fields: [createdBy], references: [id])
  apiCallLogs ApiCallLog[]

  @@index([workspaceId, status])
  @@map("api_keys")
}

model ApiCallLog {
  id             String   @id @default(uuid()) @db.Uuid
  deploymentId   String   @map("deployment_id") @db.Uuid
  apiKeyId       String?  @map("api_key_id") @db.Uuid
  endpointHash   String   @map("endpoint_hash")
  inputTokens    Int      @map("input_tokens")
  outputTokens   Int      @map("output_tokens")
  latencyMs      Int      @map("latency_ms")
  statusCode     Int      @map("status_code")
  /// Estimated USD cost for this call
  costUsd        Float?   @map("cost_usd")
  /// true = primary provider responded; false = failover was triggered
  isFailover     Boolean  @default(false) @map("is_failover")
  errorMessage   String?  @map("error_message")
  createdAt      DateTime @default(now()) @map("created_at")

  deployment Deployment @relation(fields: [deploymentId], references: [id])
  apiKey     ApiKey?    @relation(fields: [apiKeyId], references: [id])

  @@index([endpointHash])
  @@index([apiKeyId, createdAt])
  @@map("api_call_logs")
}

// ─── Phase 5: Agents ─────────────────────────────────────────────────────────

model Agent {
  id             String       @id @default(uuid()) @db.Uuid
  workspaceId    String       @map("workspace_id") @db.Uuid
  name           String
  description    String?
  status         agent_status @default(draft)
  currentVersion String?      @map("current_version")
  createdBy      String       @map("created_by") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User           @relation(fields: [createdBy], references: [id])
  versions  AgentVersion[]

  @@index([workspaceId, status])
  @@map("agents")
}

model AgentVersion {
  id                 String   @id @default(uuid()) @db.Uuid
  agentId            String   @map("agent_id") @db.Uuid
  versionNumber      Int      @map("version_number")
  /// React Flow graph JSON: { nodes: [...], edges: [...] }
  workflowDefinition Json     @map("workflow_definition")
  createdBy          String   @map("created_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at")

  agent   Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  creator User  @relation(fields: [createdBy], references: [id])

  @@unique([agentId, versionNumber])
  @@map("agent_versions")
}

// ─── Phase 6: Security ────────────────────────────────────────────────────────

model AuditLog {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String       @map("user_id") @db.Uuid
  workspaceId  String?      @map("workspace_id") @db.Uuid
  action       audit_action
  resourceType String       @map("resource_type")
  resourceId   String       @map("resource_id")
  /// Optional JSON snapshot of relevant fields before/after the change
  metadata     Json?
  ipAddress    String?      @map("ip_address")
  createdAt    DateTime     @default(now()) @map("created_at")

  user      User       @relation(fields: [userId], references: [id])
  workspace Workspace? @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}
